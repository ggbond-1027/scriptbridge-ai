LLM_PROVIDER=api
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_API_KEY_SECRET_REF=
MODEL_NAME=gpt-5.5
MODEL_SECRET_STUDIO_PROD=

JOB_QUEUE_MODE=background
JOB_BROKER_URL=
REDIS_URL=
JOB_BROKER_QUEUE=scriptbridge:jobs:default
JOB_BROKER_POP_TIMEOUT_SECONDS=1
WORKER_IDLE_SLEEP_SECONDS=1

DELIVERY_ARTIFACT_PROVIDER=local
DELIVERY_ARTIFACT_LOCAL_DIR=
DELIVERY_ARTIFACT_ENDPOINT=
DELIVERY_ARTIFACT_BUCKET=
DELIVERY_ARTIFACT_ACCESS_KEY_ID=
DELIVERY_ARTIFACT_SECRET_ACCESS_KEY=
DELIVERY_ARTIFACT_REGION=us-east-1
DELIVERY_ARTIFACT_FORCE_PATH_STYLE=
DELIVERY_ARTIFACT_PREFIX=
DELIVERY_ARTIFACT_DOMAIN=
DELIVERY_ARTIFACT_QINIU_ACCESS_KEY=
DELIVERY_ARTIFACT_QINIU_SECRET_KEY=
DELIVERY_ARTIFACT_QINIU_DOMAIN=
DELIVERY_ARTIFACT_QINIU_UPLOAD_TOKEN_EXPIRES=3600
DELIVERY_ARTIFACT_QINIU_DOWNLOAD_URL_EXPIRES=3600
DELIVERY_SIGNING_SECRET=

IMPORT_SECURITY_SCANNER=local
IMPORT_SECURITY_EXTERNAL_ENDPOINT=
IMPORT_SECURITY_EXTERNAL_SCANNER_NAME=clamav-http
IMPORT_SECURITY_EXTERNAL_TIMEOUT_SECONDS=15
IMPORT_SECURITY_ON_UNAVAILABLE=block

