# ============================================================
# NovelScripter 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# -------------------- 数据库 --------------------
DATABASE_URL=postgresql://qiyunniu:qiyunniu_dev_password@db:5432/qiyunniu_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -------------------- Redis --------------------
REDIS_URL=redis://redis:6379/0
REDIS_BACKEND_URL=redis://redis:6379/1

# -------------------- MinIO 对象存储 --------------------
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=qiyunniu_minio_access
MINIO_SECRET_KEY=qiyunniu_minio_secret
MINIO_BUCKET_SCREENPLAYS=screenplays
MINIO_BUCKET_EXPORTS=exports
MINIO_SECURE=false

# -------------------- LLM - OpenAI / 兼容接口 --------------------
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o
OPENAI_ORG_ID=

# -------------------- LLM - DeepSeek --------------------
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# -------------------- LLM - 智谱 GLM --------------------
GLM_API_KEY=your-glm-api-key-here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_NAME=glm-4

# -------------------- LLM 供应商选择 --------------------
# api: 使用远程 API (OpenAI/DeepSeek/GLM 等)
# local: 使用本地模型 (Ollama/vLLM)
LLM_PROVIDER=api

# -------------------- 本地模型配置 (LLM_PROVIDER=local 时生效) --------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen2.5:14b
VLLM_BASE_URL=http://vllm:8001
VLLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_MODEL_LEN=8192

# -------------------- LLM 通用参数 --------------------
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# -------------------- Celery Worker --------------------
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CELERY_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# -------------------- CORS 跨域设置 --------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_MAX_AGE=86400

# -------------------- JWT 认证 --------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------- 应用设置 --------------------
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# -------------------- 前端设置 --------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=NovelScripter
NEXT_PUBLIC_APP_VERSION=1.0.0

# -------------------- PostgreSQL --------------------
POSTGRES_USER=qiyunniu
POSTGRES_PASSWORD=qiyunniu_dev_password
POSTGRES_DB=qiyunniu_dev

# -------------------- Redis --------------------
REDIS_HOST=redis
REDIS_PORT=6379
